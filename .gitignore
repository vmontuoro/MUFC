# Ignore everything by default...
/*

# ...then publish only the static site files
!.gitignore
!README.md
!index.html
!Manningham_setup_packup_plan.html
!Manningham_schedule_clashes.html
!Manningham_fixtures.html
!Manningham_fixtures_and_overlaps.xlsx
!logos/
!logos/*.png

# PRIVATE — never publish. Confidential officials list & any merged manager pages.
# (Already excluded by the /* rule above; listed explicitly as a safeguard.)
TeamOfficials_*.csv
*_PRIVATE.*
!duties_data.js

# ---- Build pipeline (generators + current raw dumps) & refresh skill: versioned for backup ----
# Only the .py generators + raw_*.txt are tracked; experiment junk (parts/, *.b64, *.lines,
# __pycache__) and machine-local .claude/settings stay out.
!build/
build/*
!build/*.py
!build/raw_*.txt
!build/overrides.json
!.claude/
.claude/*
!.claude/skills/
!.claude/skills/**
